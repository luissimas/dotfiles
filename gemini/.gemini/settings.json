{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "theme": "Default",
    "hideBanner": true,
    "useFullWidth": true,
    "hideWindowTitle": true,
    "accessibility": {
      "disableLoadingPhrases": true,
      "enableLoadingPhrases": false
    }
