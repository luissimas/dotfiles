  "general": {
    "vimMode": true,
    "enablePromptCompletion": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    },
    "preferredEditor": "neovim"
  },
  "output": {
    "format": "text"
  }
}