" Core
set nocompatible
syntax on
filetype plugin indent on
set encoding=utf-8
set backspace=indent,eol,start
set hidden
set nomodeline
set belloff=all
set ttimeoutlen=50

" UI
set number relativenumber
set ruler
set showcmd
set laststatus=2
set statusline=%f\ %m%r%h%w\ %=%y\ %l:%c\ %p%%
set wildmenu
set wildmode=longest:full,full
set scrolloff=3
set splitbelow splitright

" Search
set incsearch
set hlsearch
set ignorecase
set smartcase

" Indent
set expandtab
set tabstop=2
set shiftwidth=2
set softtabstop=2
set autoindent

" Files
set nobackup
set nowritebackup
set noswapfile
set noundofile
set viminfo='100,<50,s10,h
